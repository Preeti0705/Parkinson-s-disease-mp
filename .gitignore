# .gitignore for Parkinson's Disease Voice Detection project

# Python cache
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/

# Build artifacts
*.egg-info/
dist/
build/
.eggs/

# Large data files
*.rar

# Root-level leftover model files (generated by legacy src/model.py)
/parkinsons_rf_model.pkl
/scaler.pkl

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
